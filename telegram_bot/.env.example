# SecureVista Telegram Bot — Environment Variables
# Copy this file to .env and fill in your values

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated list of authorized Telegram chat IDs
ALLOWED_CHAT_IDS=123456789,987654321

# Path to the CCTV snapshot frames directory
SNAPSHOTS_DIR=../logs/object_frames

# Guard phone number for voice call escalations
GUARD_PHONE=+918169803818

# Optional: Path to the main system's SQLite database
DB_PATH=../securevista.db

# Optional: Backend health check URL
BACKEND_URL=http://localhost:8080
